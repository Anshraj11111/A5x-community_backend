NODE_ENV=development
PORT=4000

# MongoDB Atlas — get from atlas.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/a5x_db?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=minimum_32_characters_long_random_secret_key_here
JWT_EXPIRES_IN=7d

# CORS — frontend URL
CLIENT_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
